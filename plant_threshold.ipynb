   "source": [
    "import matplotlib.pyplot as plt\n",
    "img = plt.imread('figures/poppy.png')\n",
    "threshold = 0.6\n",
    "thresholded = img.copy()\n",
    "thresholded[img[:,:,0] < threshold] = 0\n",
    "\n",
    "plt.figure(figsize=(20,16))\n",
    "plt.subplot(121)\n",
    "plt.imshow(img)\n",
    "plt.subplot(122)\n",
    "plt.imshow(thresholded)\n",
    "plt.show()"
   ]
  }
 ],
